# Gmail OAuth files must remain local and untracked. Use absolute local paths.
# If omitted, existing ignored local files at secrets/gmail/ are detected automatically.
GMAIL_CREDENTIALS_PATH=C:\path\outside\repo\credentials.json
GMAIL_TOKEN_PATH=C:\path\outside\repo\token.json
GMAIL_REVIEW_LABEL=Phishing Review
MAILBOX_PROVIDER=gmail

# Automatic Gmail quarantine is fail-closed: it requires both settings below.
# Keep SHADOW_MODE=true for analysis-only sync; mock mailbox actions are still simulated.
SHADOW_MODE=true
ALLOW_LIVE_GMAIL_ACTIONS=false
SYNC_DEFAULT_LIMIT=25

# Local frontend origins permitted to call the FastAPI backend.
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
